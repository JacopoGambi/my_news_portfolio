# ====================================
# MyNews - API Keys Configuration
# ====================================
# Copia questo file in .env.local e inserisci le tue API key.
# I dati di mercato vengono da Yahoo Finance (nessuna key necessaria).
# Senza API key per le news l'app funziona in modalità DEMO con dati simulati.

# GNews.io - Per notizie finanziarie e geopolitiche in tempo reale
# Registrati su: https://gnews.io/register (piano gratuito: 100 req/giorno)
GNEWS_KEY=
